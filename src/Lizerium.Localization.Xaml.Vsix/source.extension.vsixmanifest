<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011">
  <Metadata>
    <Identity Id="Lizerium.Localization.Xaml.Vsix" Version="1.0.2" Language="en-US" Publisher="Dvurechensky" />
    <DisplayName>Lizerium Localization XAML Tools</DisplayName>
    <Description xml:space="preserve">Adds Visual Studio XAML light bulb actions for WPF localization. Select XAML text or place the caret inside a literal, run "Create XAML localization key", and the extension will add/update RESX keys, generate AI translations through the configured Ollama/LibreTranslate servers, and insert {loc:Loc Key}. Existing project LocExtension is reused; otherwise a small source-only runtime LocExtension is added to the project. Server URLs and model are configurable in Tools - Options - Lizerium Localization - AI Servers.</Description>
    <MoreInfo>https://github.com/Lizerium/Lizerium.Localization.Toolkit</MoreInfo>
    <Icon>LOGO_400x400.png</Icon>
    <PreviewImage>LOGO_400x400.png</PreviewImage>
    <Tags>Localization;XAML;WPF;RESX;Lizerium</Tags>
  </Metadata>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Community" Version="[17.0,18.0)">
      <ProductArchitecture>amd64</ProductArchitecture>
    </InstallationTarget>
    <InstallationTarget Id="Microsoft.VisualStudio.Pro" Version="[17.0,18.0)">
      <ProductArchitecture>amd64</ProductArchitecture>
    </InstallationTarget>
    <InstallationTarget Id="Microsoft.VisualStudio.Enterprise" Version="[17.0,18.0)">
      <ProductArchitecture>amd64</ProductArchitecture>
    </InstallationTarget>
  </Installation>
  <Dependencies>
    <Dependency Id="Microsoft.Framework.NDP" DisplayName="Microsoft .NET Framework" Version="[4.7.2,)" />
  </Dependencies>
  <Assets>
    <Asset Type="Microsoft.VisualStudio.MefComponent" Path="|Lizerium.Localization.Xaml.Vsix|" />
    <Asset Type="Microsoft.VisualStudio.VsPackage" Path="|Lizerium.Localization.Xaml.Vsix|" />
  </Assets>
  <Prerequisites>
    <Prerequisite Id="Microsoft.VisualStudio.Component.CoreEditor" Version="[17.0,18.0)" DisplayName="Visual Studio core editor" />
  </Prerequisites>
</PackageManifest>
