<Window
    x:Class="Lizerium.Localization.GUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Lizerium Localization"
    Width="1120"
    Height="720"
    MinWidth="920"
    MinHeight="560"
    Background="#F7F8FA">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                <Button
                    Width="132"
                    Height="34"
                    Margin="0,0,8,0"
                    Click="OpenProject_Click"
                    Content="Open folder project" />
                <Button
                    Width="96"
                    Height="34"
                    Margin="0,0,8,0"
                    Click="Reload_Click"
                    Content="Reload" />
                <Button
                    Width="116"
                    Height="34"
                    Click="Sync_Click"
                    Content="Sync missing" />
            </StackPanel>
            <TextBlock
                VerticalAlignment="Center"
                Foreground="#4B5563"
                Text="{Binding ProjectPath}"
                TextTrimming="CharacterEllipsis" />
        </DockPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <DataGrid
                Grid.Column="0"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                CellEditEnding="Entries_CellEditEnding"
                GridLinesVisibility="Horizontal"
                IsReadOnly="False"
                ItemsSource="{Binding Entries}"
                RowHeight="32">
                <DataGrid.Resources>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasError}" Value="True">
                                <Setter Property="Background" Value="#FFF1F2" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding HasWarning}" Value="True">
                                <Setter Property="Background" Value="#FFFBEB" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="2*"
                        Binding="{Binding Key}"
                        Header="KEY"
                        IsReadOnly="True" />
                    <DataGridTextColumn
                        Width="2*"
                        Binding="{Binding Ru, UpdateSourceTrigger=PropertyChanged}"
                        Header="RU" />
                    <DataGridTextColumn
                        Width="2*"
                        Binding="{Binding En, UpdateSourceTrigger=PropertyChanged}"
                        Header="EN" />
                    <DataGridTextColumn
                        Width="80"
                        Binding="{Binding Params}"
                        Header="PARAMS"
                        IsReadOnly="True" />
                    <DataGridTextColumn
                        Width="170"
                        Binding="{Binding Status}"
                        Header="STATUS"
                        IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>

            <Border
                Grid.Column="2"
                Padding="14"
                Background="White"
                BorderBrush="#D6DAE0"
                BorderThickness="1">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="Add key" />
                    <TextBlock Text="Namespace" />
                    <TextBox Margin="0,4,0,10" Text="{Binding NewNamespace, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Name" />
                    <TextBox Margin="0,4,0,10" Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="RU" />
                    <TextBox
                        MinHeight="58"
                        Margin="0,4,0,10"
                        AcceptsReturn="True"
                        Text="{Binding NewRu, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap" />
                    <TextBlock Text="EN" />
                    <TextBox
                        MinHeight="58"
                        Margin="0,4,0,12"
                        AcceptsReturn="True"
                        Text="{Binding NewEn, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap" />
                    <Button
                        Height="34"
                        Click="AddKey_Click"
                        Content="Add localization key" />
                    <TextBlock
                        Margin="0,12,0,0"
                        Foreground="#4B5563"
                        Text="{Binding AddKeyPreview}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
