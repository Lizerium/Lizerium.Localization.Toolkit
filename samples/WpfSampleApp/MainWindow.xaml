<Window
    x:Class="WpfSampleApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Localization Sample"
    Width="520"
    Height="260">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock
                x:Name="TitleText"
                Margin="0,0,0,12"
                FontSize="24"
                FontWeight="SemiBold" />
            <TextBlock
                x:Name="MessageText"
                Margin="0,0,0,16"
                FontSize="15"
                TextWrapping="Wrap" />
            <TextBlock
                x:Name="CustomText"
                Margin="0,0,0,16"
                FontSize="15"
                Text="Какой то текст в блоке"
                TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal">
                <Button
                    Width="92"
                    Height="32"
                    Margin="0,0,8,0"
                    Click="English_Click"
                    Content="English" />
                <Button
                    Width="92"
                    Height="32"
                    Click="Russian_Click"
                    Content="Русский" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
