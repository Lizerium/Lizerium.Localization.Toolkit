<Window x:Class="WpfSampleApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Localization Sample" Height="260" Width="520">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock x:Name="TitleText" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,12" />
            <TextBlock x:Name="MessageText" FontSize="15" TextWrapping="Wrap" Margin="0,0,0,16" />
            <StackPanel Orientation="Horizontal">
                <Button Width="92" Height="32" Margin="0,0,8,0" Click="English_Click" Content="English" />
                <Button Width="92" Height="32" Click="Russian_Click" Content="Russian" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
